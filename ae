#!/usr/bin/env bash
#
# Axeloot Æ — one-command production installer (Linux, Docker-based).
#
# The command you give a customer:
#
#   curl -fsSL https://get.axeloot.com/ae | sudo bash -s -- \
#       --registry-user <deploy-user> --registry-token <read:packages token>
#
# or, air-gapped (no internet / no registry access):
#
#   sudo bash bootstrap.sh --bundle axeloot-ae-v5.2.0.tar.gz
#
# What it does:
#   1. Installs Docker Engine + compose plugin if missing (get.docker.com)
#   2. Logs in to ghcr.io (when registry credentials are provided)
#   3. Pulls the Axeloot Æ server image (channel-aware: stable → :latest,
#      edge → :edge) — or side-loads it from an offline bundle
#   4. Extracts the canonical docker-compose.prod.yml, .env.prod.example and
#      scripts/update.sh from the image (/app/dist) into the install dir,
#      so the deployment files always match the running version
#   5. Generates .env.prod with strong random secrets (only if absent —
#      re-running never overwrites an existing configuration)
#   6. Installs the customer license when provided (--license)
#   7. Starts the stack, waits for /api/health/ready, prints next steps
#
# Idempotent: safe to re-run on a configured host — it becomes "pull + up".
# Day-2 updates use the extracted ./update.sh (channel-aware, backup+rollback).
#
# Flags:
#   --dir <path>             install directory        (default /opt/axeloot)
#   --channel stable|edge    release channel          (default stable)
#   --version <tag>          pin an exact image tag   (overrides channel default)
#   --registry-user <user>   ghcr.io username for docker login
#   --registry-token <tok>   ghcr.io token (read:packages)
#   --bundle <file>          offline image bundle (.tar / .tar.gz) — skips registry
#   --license <file>         customer .lic file → <dir>/license/customer.lic
#   --license-keys <file>    Ops-issued keys.json → <dir>/license/keys.json
#   --no-start               prepare everything but do not start the stack
#
set -euo pipefail

INSTALL_DIR="/opt/axeloot"
CHANNEL="stable"
VERSION=""
REG_USER="${AXELOOT_REGISTRY_USER:-}"
REG_TOKEN="${AXELOOT_REGISTRY_TOKEN:-}"
BUNDLE=""
LICENSE_FILE=""
LICENSE_KEYS=""
NO_START=0
IMAGE_REPO="ghcr.io/axeloot-enterprise/axelootae-server"

log() { printf '\033[1;32m[axeloot]\033[0m %s\n' "$*"; }
warn(){ printf '\033[1;33m[axeloot] WARN:\033[0m %s\n' "$*" >&2; }
err() { printf '\033[1;31m[axeloot] ERROR:\033[0m %s\n' "$*" >&2; }
die() { err "$*"; exit 1; }

while [ $# -gt 0 ]; do
  case "$1" in
    --dir)            INSTALL_DIR="${2:?--dir needs a path}"; shift 2;;
    --channel)        CHANNEL="${2:?--channel needs stable|edge}"; shift 2;;
    --version)        VERSION="${2:?--version needs a tag}"; shift 2;;
    --registry-user)  REG_USER="${2:?--registry-user needs a value}"; shift 2;;
    --registry-token) REG_TOKEN="${2:?--registry-token needs a value}"; shift 2;;
    --bundle)         BUNDLE="${2:?--bundle needs a file}"; shift 2;;
    --license)        LICENSE_FILE="${2:?--license needs a file}"; shift 2;;
    --license-keys)   LICENSE_KEYS="${2:?--license-keys needs a file}"; shift 2;;
    --no-start)       NO_START=1; shift;;
    -h|--help)        grep '^#' "$0" | sed 's/^# \{0,1\}//' | head -44; exit 0;;
    *)                die "unknown argument: $1 (try --help)";;
  esac
done

case "$CHANNEL" in stable|edge) : ;; *) die "--channel must be stable or edge";; esac
if [ -z "$VERSION" ]; then
  case "$CHANNEL" in
    edge)   VERSION="edge";;
    stable) VERSION="latest";;
  esac
fi

[ "$(id -u)" -eq 0 ] || die "run as root:  curl -fsSL … | sudo bash -s -- <flags>"

if [ -f /etc/os-release ]; then
  . /etc/os-release
  log "detected OS: ${PRETTY_NAME:-unknown}"
  case "${ID:-}" in
    ubuntu|debian) : ;;
    *) warn "tested on Ubuntu 22.04+/Debian 12+ — continuing on ${ID:-unknown}";;
  esac
fi

# ── 1. Docker Engine + compose plugin ────────────────────────────────────────
if ! command -v docker >/dev/null 2>&1; then
  log "Docker not found — installing via get.docker.com"
  command -v curl >/dev/null 2>&1 || { apt-get update -qq && apt-get install -y -qq curl; }
  curl -fsSL https://get.docker.com | sh
  systemctl enable --now docker
fi
docker compose version >/dev/null 2>&1 || die "docker compose plugin missing (Docker install incomplete?)"
log "Docker: $(docker --version)"

# ── 2. Registry access ───────────────────────────────────────────────────────
if [ -n "$BUNDLE" ]; then
  [ -f "$BUNDLE" ] || die "bundle not found: $BUNDLE"
  log "loading offline image bundle: $BUNDLE"
  case "$BUNDLE" in
    *.gz) gunzip -c "$BUNDLE" | docker load;;
    *)    docker load -i "$BUNDLE";;
  esac
else
  if [ -n "$REG_TOKEN" ]; then
    log "logging in to ghcr.io as ${REG_USER:-token}"
    printf '%s' "$REG_TOKEN" | docker login ghcr.io -u "${REG_USER:-token}" --password-stdin
  fi
  log "pulling ${IMAGE_REPO}:${VERSION}"
  docker pull "${IMAGE_REPO}:${VERSION}" \
    || die "image pull failed — check --registry-user/--registry-token, or use --bundle for air-gapped installs"
fi

# ── 3. Install directory + deployment files from the image ──────────────────
mkdir -p "$INSTALL_DIR"/{backups,license,secrets/keys}
cd "$INSTALL_DIR"

extract_dist() {
  # The image ships its own deployment files at /app/dist — extract them so
  # compose/update.sh always match the running server version.
  local cid
  cid="$(docker create "${IMAGE_REPO}:${VERSION}")" || return 1
  local ok=0
  if docker cp "$cid:/app/dist/." "$INSTALL_DIR/.dist-tmp" 2>/dev/null; then ok=1; fi
  docker rm -f "$cid" >/dev/null
  [ "$ok" = "1" ] || return 1
  # compose + update.sh always refresh (they must match the image);
  # the env example refreshes too — the real .env.prod is never touched.
  [ -f .dist-tmp/docker-compose.prod.yml ] && mv .dist-tmp/docker-compose.prod.yml docker-compose.prod.yml
  [ -f .dist-tmp/update.sh ] && { mv .dist-tmp/update.sh update.sh; chmod +x update.sh; }
  [ -f .dist-tmp/uninstall.sh ] && { mv .dist-tmp/uninstall.sh uninstall.sh; chmod +x uninstall.sh; }
  [ -f .dist-tmp/.env.prod.example ] && mv .dist-tmp/.env.prod.example .env.prod.example
  rm -rf .dist-tmp
  return 0
}

if extract_dist; then
  log "deployment files extracted from image (/app/dist)"
else
  warn "image has no /app/dist (pre-5.3 image) — writing built-in compose file"
  cat > docker-compose.prod.yml <<'COMPOSE_EOF'
# Written by bootstrap.sh (fallback for images without /app/dist).
# Canonical copy lives in the repo as docker-compose.prod.yml.
name: axeloot-ae

services:
  postgres:
    image: postgres:16-alpine
    restart: always
    environment:
      POSTGRES_USER: ${POSTGRES_USER:?set POSTGRES_USER in .env.prod}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:?set POSTGRES_PASSWORD in .env.prod}
      POSTGRES_DB: ${POSTGRES_DB:-axeloot}
    volumes:
      - pg_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER}"]
      interval: 10s
      timeout: 3s
      retries: 12

  redis:
    image: redis:7-alpine
    restart: always
    command: ["redis-server", "--appendonly", "yes", "--requirepass", "${REDIS_PASSWORD:?set REDIS_PASSWORD in .env.prod}"]
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "$${REDIS_PASSWORD}", "ping"]
      interval: 10s
      timeout: 3s
      retries: 12

  server:
    image: ghcr.io/axeloot-enterprise/axelootae-server:${AXELOOT_VERSION:-latest}
    restart: always
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_started
    env_file:
      - .env.prod
    environment:
      DATABASE_URL: postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB:-axeloot}
      REDIS_URL: redis://:${REDIS_PASSWORD}@redis:6379/0
      AXELOOT_ENV: production
      AXELOOT_RELEASE_CHANNEL: ${AXELOOT_CHANNEL:-stable}
      COOKIE_SECURE: "1"
      REDIS_REQUIRED_FOR_RATE_LIMITING: "1"
      AXELOOT_LICENSE_FILE: /license/customer.lic
      AXELOOT_LICENSE_KEYS_FILE: /license/keys.json
      AXELOOT_LICENSE_PRODUCT: axeloot-ae
    volumes:
      - screenshots:/app/screenshots
      - packages:/app/packages
      - ./secrets/keys:/app/.keys:ro
      - ./license:/license:ro
    ports:
      - "127.0.0.1:8000:8000"
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://127.0.0.1:8000/api/health/ready"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 40s

volumes:
  pg_data:
  redis_data:
  screenshots:
  packages:
COMPOSE_EOF
fi

# ── 4. .env.prod — generate once, never overwrite ────────────────────────────
gen_secret() { head -c 64 /dev/urandom | base64 | tr -dc 'A-Za-z0-9' | head -c 48; }

if [ -f .env.prod ]; then
  log ".env.prod already exists — keeping it (re-run = update, not reinstall)"
else
  log "generating .env.prod with fresh secrets"
  cat > .env.prod <<ENV_EOF
# Axeloot Æ production environment — generated by bootstrap.sh on $(date -u +%Y-%m-%dT%H:%M:%SZ).
# KEEP THIS FILE SAFE: it holds every secret of this deployment.
AXELOOT_CHANNEL=${CHANNEL}
AXELOOT_VERSION=${VERSION}

POSTGRES_USER=axeloot
POSTGRES_PASSWORD=$(gen_secret)
POSTGRES_DB=axeloot

REDIS_PASSWORD=$(gen_secret)

SECRET_KEY=$(gen_secret)
ENROLLMENT_TOKEN_SALT=$(gen_secret)

# Optional hardening — see .env.prod.example:
# AGENT_SECRET=
# AXELOOT_EVIDENCE_KEY=
ENV_EOF
  chmod 600 .env.prod
fi

# ── 5. License ───────────────────────────────────────────────────────────────
if [ -n "$LICENSE_FILE" ]; then
  [ -f "$LICENSE_FILE" ] || die "license file not found: $LICENSE_FILE"
  install -m 640 "$LICENSE_FILE" license/customer.lic
  log "license installed → license/customer.lic"
fi
if [ -n "$LICENSE_KEYS" ]; then
  [ -f "$LICENSE_KEYS" ] || die "license keys file not found: $LICENSE_KEYS"
  install -m 640 "$LICENSE_KEYS" license/keys.json
  log "license keys installed → license/keys.json"
fi
if [ ! -f license/customer.lic ]; then
  warn "no license installed — the server starts in limited mode; add it later with:"
  warn "  cp customer.lic $INSTALL_DIR/license/customer.lic && cp keys.json $INSTALL_DIR/license/keys.json"
fi

# ── 6. Start + health ────────────────────────────────────────────────────────
if [ "$NO_START" = "1" ]; then
  log "--no-start: stack prepared in $INSTALL_DIR — start it with:"
  log "  cd $INSTALL_DIR && docker compose --env-file .env.prod -f docker-compose.prod.yml up -d"
  exit 0
fi

log "starting the stack"
docker compose --env-file .env.prod -f docker-compose.prod.yml up -d

HEALTH_URL="http://127.0.0.1:8000/api/health/ready"
log "waiting for $HEALTH_URL (up to 180s)"
elapsed=0
until curl -fsS "$HEALTH_URL" >/dev/null 2>&1; do
  sleep 3; elapsed=$((elapsed+3))
  [ "$elapsed" -ge 180 ] && die "server did not become healthy — inspect: docker compose --env-file .env.prod -f docker-compose.prod.yml logs server"
done

HOST_IP="$(hostname -I 2>/dev/null | awk '{print $1}')"
cat <<SUMMARY_EOF

$(printf '\033[1;32m')════════════════════════════════════════════════════════════════$(printf '\033[0m')
 Axeloot Æ is up.

   Console (local):     http://127.0.0.1:8000
   Install directory:   $INSTALL_DIR
   Release channel:     $CHANNEL  (image tag: $VERSION)

 Next steps
   1. TLS: the server listens on 127.0.0.1 only — put your reverse proxy
      in front of it (an nginx site config ships in the repo at
      deploy/nginx.conf) and point it at 127.0.0.1:8000.
      Until then, reach it via an SSH tunnel:
        ssh -L 8000:127.0.0.1:8000 <this-host>   → http://localhost:8000
   2. Sign in and change the default admin password immediately.
   3. Deploy agents: Console → Settings → Agents (download per-OS
      installers with the enrollment token embedded).
   4. Updates later:  cd $INSTALL_DIR && sudo ./update.sh
      (channel-aware; backs up the DB and auto-rolls-back on failure)
$(printf '\033[1;32m')════════════════════════════════════════════════════════════════$(printf '\033[0m')
SUMMARY_EOF
[ -n "$HOST_IP" ] && log "LAN address (behind your proxy/TLS): https://$HOST_IP/"
exit 0
